apiVersion: apps/v1
kind: Deployment

metadata:
  name: saas-frontend
  namespace: saas-app

spec:
  replicas: 1

  selector:
    matchLabels:
      app: saas-frontend

  template:
    metadata:
      labels:
        app: saas-frontend

    spec:
      containers:
        - name: saas-frontend

          image: rks1947/saas-multi-tenant-app-ui:33

          imagePullPolicy: IfNotPresent

          ports:
            - containerPort: 80